{
  "name": "opensyber-mcp-watch-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for OpenSyber mcp-watch: the local rug-pull detection CLI, its shared detection core, and the cloud (SaaS) layer.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/opensyber-mcp-watch.git"
  },
  "homepage": "https://opensyber.cloud",
  "bugs": "https://github.com/finsavvyai/opensyber-mcp-watch/issues",
  "author": "OpenSyber <support@opensyber.cloud>"
