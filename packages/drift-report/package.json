{
  "name": "@opensyber/mcp-watch-drift-report",
  "version": "0.1.0",
  "private": true,
  "description": "Growth/research harness: watch public MCP servers over time and generate the MCP Drift Report (the data behind the launch).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-drift-report": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: skip (no eslint config)'",
    "snapshot": "node dist/cli.js snapshot",
    "report": "node dist/cli.js report"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@opensyber/mcp-watch-core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/opensyber-mcp-watch.git",
    "directory": "packages/drift-report"
  },
  "author": "OpenSyber <support@opensyber.cloud>"
}
